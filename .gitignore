# ============================================================
# LeapWorkSpace .gitignore
# C++ V8 Native Addon (leap-vm) + Node.js Runtime (leap-env)
# ============================================================

# ------ Node.js ------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ------ C++ / Native Build ------
# CMake build output
leap-vm/build/
build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt

# Visual Studio
*.vcxproj.user
*.vcxproj.filters
*.sln
*.suo
*.user
*.userosscache
*.sln.docstates
.vs/
*.VC.db
*.VC.VC.opendb

# Compiled objects and binaries
*.o
*.obj
*.pdb
*.ilk
*.exp
*.lib
*.dll
*.so
*.dylib
*.exe
*.node

# Static analysis / cache
*.ncb
*.opensdf
*.sdf
ipch/

# ------ esbuild / Bundle output ------
leap-env/src/build/dist/
leap-env/src/build/out/
*.bundle.js
*.bundle.mjs

# ------ Test results (timestamped, auto-generated) ------
tests/results/
tests/baselines/*.json

# ------ Logs ------
logs/
*.log
*.log.*

# ------ Environment / Secrets ------
.env
.env.*
!.env.example

# ------ OS generated ------
.DS_Store
Thumbs.db
desktop.ini

# ------ Editor ------
# VS Code - keep shared settings, ignore personal/local overrides
.vscode/*.log
.vscode/extensions.json

# Claude Code - keep shared settings, ignore local overrides
.claude/settings.local.json

# ------ Temporary / Working files ------
work/
tmp/
temp/
*.tmp
*.bak
*.swp
*~

# ------ Python build artifacts (build scripts) ------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ------ PowerShell ------
# (no common artifacts to ignore)
.gitnexus
